.menu-label {
    color: white;
    transition-property: color, scale;
    transition-duration: 0.15s;
    font-size: 25px;
    -unity-font-definition: url("project://database/Assets/Fonts/Rationale-Regular.ttf?fileID=12800000&guid=78bc9a36a495bc944b4295e1e828fcc2&type=3#Rationale-Regular");
    -unity-font-style: bold-and-italic;
    align-self: flex-start;
    align-items: auto;
    height: 23px;
}

.menu-label:hover {
    background-color: rgba(255, 255, 255, 0.1);
    scale: 1.05;
}
